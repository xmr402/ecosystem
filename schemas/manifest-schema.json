{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "name", "category", "tagline", "status", "author"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "category": { "enum": ["guards", "gateways", "agent-skills", "services", "wallets", "tools", "misc"] },
    "tagline": { "type": "string", "maxLength": 100 },
    "status": { "type": "string" },
    "url": { "type": "string" },
    "github": { "type": "string" },
    "author": { "type": "string" },
    "logo": { "type": "string" }
  }
}